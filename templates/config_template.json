{
  "_comment": "AutoPhD config.json — generated by brain/connect.py, maintained by Main Agent. All fields documented below.",

  "run_id": "exp-{project}-{hypothesis_id}-{YYYYMMDD-HHMMSS}",
  "hypothesis_id": "H001",
  "project": "{project_name}",
  "branch": "exp/{project}-{hypothesis_id}-{YYYYMMDD-HHMMSS}",
  "experiment_repo": "https://github.com/{owner}/{repo}",
  "brain_repo": "https://github.com/{owner}/autoresearch",

  "experiment": {
    "entry_point": "run_experiment.py",
    "method_name": "{treatment_method}",
    "baseline_name": "{control_method}",
    "benchmark_name": "{benchmark}",
    "benchmark_dim": 100,
    "budget": 200,
    "n_seeds": 20,
    "initial_sobol": 10,
    "timeout_minutes": 90,
    "interrupt_poll_every": 10,
    "diagnostic_freq": 5
  },

  "paths": {
    "log": ".autoresearch/log.csv",
    "diagnostics": ".autoresearch/diagnostics.csv",
    "interrupt": ".autoresearch/interrupt.json",
    "heartbeat": ".autoresearch/heartbeat.json",
    "completion_flag": ".autoresearch/completion_flag.json",
    "restart_flag": ".autoresearch/restart_flag.json",
    "state": ".autoresearch/state.md",
    "budget": ".autoresearch/budget.json",
    "agent_comms": ".autoresearch/agent_comms.jsonl",
    "agent_dialogue": ".autoresearch/agent_dialogue.md"
  },

  "permissions": {
    "allowed_paths": [
      "src/methods/",
      "src/config/",
      ".autoresearch/"
    ],
    "protected_paths": [
      "src/benchmarks/",
      "data/",
      "run_experiment.py",
      ".github/"
    ],
    "allow_network": false,
    "allowed_domains": []
  },

  "budget": {
    "n_experiment_trials": 5,
    "max_agent_calls_total": 50,
    "max_cost_usd": 10.00,
    "max_tokens_by_agent": {
      "main": 100000,
      "experiment": 120000,
      "monitor": 40000,
      "analyst": 80000,
      "summarizer": 20000,
      "tester": 40000,
      "security": 20000,
      "pr_agent": 10000,
      "bug_analyst": 40000
    }
  },

  "approval_mode": "approval_required",

  "exploration_mode": "GUIDED",

  "status": "setup",

  "created_at": "{timestamp}",
  "last_updated": "{timestamp}"
}
